#!/bin/bash

# 1. Check if the user provided at least one argument
if [ -z "$1" ]; then
    echo "Usage: ./script.sh <command> [arguments]"
    echo "Example: ./script.sh add my_folder"
    exit 1
fi

# 2. Compile the C program
gcc main.c commands.c -o my_tool

# 3. Check if compilation was successful
if [ $? -eq 0 ]; then
    # 4. Run the program with ALL arguments passed to the script using "$@"
    ./my_tool "$@"
else
    echo "Compilation failed!"
    exit 1
fi